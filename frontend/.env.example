# ZedEarn Frontend Environment Variables
# Copy this file to .env and fill in the values.
# VITE_* variables are baked into the bundle at build time — set them in Vercel
# before the first deploy, then trigger a redeploy if you change them later.

# Development (local backend):
#   VITE_API_URL=http://localhost:5001/api
# Production — set to your Render backend URL (no trailing slash):
VITE_API_URL=https://your-backend.onrender.com/api
