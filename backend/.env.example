# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development:
MONGO_URI=mongodb://127.0.0.1:27017/zedearn
# Production (MongoDB Atlas) — replace <user>, <password>, and <cluster-id>:
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster-id>.mongodb.net/zedearn?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Development default (override in production with a strong 64-character hex secret)
JWT_SECRET=zedearn_secure_dev_secret
JWT_EXPIRE=7d

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable Redis — app degrades gracefully without it.
# Production example (Upstash): rediss://:password@hostname:port
REDIS_URL=

# ─── Cloudinary (required for image upload) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development:
#   CLIENT_URL=http://localhost:5173
# Production — set to the exact Vercel frontend URL (no trailing slash):
CLIENT_URL=https://your-app.vercel.app

# ─── SMTP (optional, for password reset emails) ────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@zedearn.zm

# ─── Environment ──────────────────────────────────────────────────────────────
# Use "production" on Render. Never commit the real .env file.
NODE_ENV=development

# ─── Logging ──────────────────────────────────────────────────────────────────
# 'debug' | 'info' | 'warn' | 'error'  (default: info in production, debug in dev)
LOG_LEVEL=info

# ─── Wallet Limits ────────────────────────────────────────────────────────────
# Maximum total withdrawal amount per user per calendar day (ZMW)
DAILY_WITHDRAWAL_LIMIT=5000

# ─── Airtel Money (Zambia) ────────────────────────────────────────────────────
# Register at: https://developers.airtel.africa/
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_COUNTRY=ZM
AIRTEL_CURRENCY=ZMW
# Encrypted PIN for B2C disbursements (obtain from Airtel onboarding)
AIRTEL_ENCPIN=

# ─── MTN Mobile Money (Zambia) ────────────────────────────────────────────────
# Register at: https://momodeveloper.mtn.com/
MTN_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_API_USER=your_mtn_api_user_uuid
MTN_API_KEY=your_mtn_api_key
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_CURRENCY=ZMW
# 'sandbox' for testing, 'mtnzambia' for production
MTN_ENVIRONMENT=sandbox

# ─── Zamtel Kwacha (Zambia) ───────────────────────────────────────────────────
# Contact Zamtel or your licensed aggregator for credentials
ZAMTEL_API_KEY=your_zamtel_api_key
ZAMTEL_API_SECRET=your_zamtel_api_secret
ZAMTEL_BASE_URL=https://api.zamtel.zm/mobile-money/v1
ZAMTEL_MERCHANT_ID=your_zamtel_merchant_id
ZAMTEL_CURRENCY=ZMW

# ─── Bank Transfer / EFT (Zambia) ─────────────────────────────────────────────
# Configure via your payment aggregator (DPO Group, Cellulant, etc.)
BANK_API_KEY=your_bank_api_key
BANK_API_SECRET=your_bank_api_secret
BANK_BASE_URL=https://api.paymentgateway.zm/v2
BANK_COMPANY_TOKEN=your_company_token
# Service type code for your aggregator's Zambia EFT product
BANK_SERVICE_TYPE=3854
BANK_CURRENCY=ZMW
