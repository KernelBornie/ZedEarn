# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001

# ─── Database ─────────────────────────────────────────────────────────────────
# Local development:
#   MONGO_URI=mongodb://127.0.0.1:27017/zedearn
# Production (MongoDB Atlas) — replace <user>, <password>, and <cluster-id>:
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-id>.mongodb.net/zedearn?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong 64-character hex secret (32 random bytes): openssl rand -hex 32
JWT_SECRET=replace_with_64_char_hex_secret_never_commit_real_value
JWT_EXPIRE=7d

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable Redis — app degrades gracefully without it.
# Production example (Upstash): rediss://:password@hostname:port
REDIS_URL=

# ─── Cloudinary (required for image upload) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Development:
#   CLIENT_URL=http://localhost:5173
# Production — set to the exact Vercel frontend URL (no trailing slash):
CLIENT_URL=https://your-app.vercel.app

# ─── Environment ──────────────────────────────────────────────────────────────
# Use "production" on Render. Never commit the real .env file.
NODE_ENV=development
